[ req ]
default_bits       = 2048
prompt             = no
default_md         = sha256
distinguished_name = dn
req_extensions     = req_ext

[ dn ]
C  = DE
O  = Lab
OU = Telemetry
CN = 192.168.2.220

[ req_ext ]
subjectAltName = @alt_names
extendedKeyUsage = serverAuth

[ alt_names ]
IP.1  = 192.168.2.220
DNS.1 = collector.lab
DNS.2 = ubuntu
